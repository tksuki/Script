local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- 設定用テーブル（もし既存のスクリプトに入れるならここは不要）
local Settings = {
    Anti = {
        AntiBurn = true -- ここをtrueにすると機能が有効になります
    }
}

task.spawn(function()
    while true do
        -- Settingsが存在し、AntiBurnが有効な場合のみ実行
        if Settings and Settings.Anti and Settings.Anti.AntiBurn then
            pcall(function()
                local char = LocalPlayer.Character
                if char then
                    -- キャラクターの中にある「火」のエフェクトをすべて探す
                    for _, v in ipairs(char:GetDescendants()) do
                        -- 1. クラスが「Fire（火）」であるか
                        -- 2. 名前が「Fire」「Burning」「OnFire」などであるか
                        if v:IsA("Fire") or v.Name == "Fire" or v.Name == "Burning" or v.Name == "OnFire" then
                            v:Destroy() -- 見つけ次第削除
                        end
                    end
                end
            end)
        end
        task.wait(0.1) -- 0.1秒ごとに監視（負荷を抑えつつ高速に消去）
    end
end)
