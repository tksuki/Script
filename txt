local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

local playerCharacter = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
LocalPlayer.CharacterAdded:Connect(function(character) 
    playerCharacter = character 
end)

getgenv().SilentAimSettings = {
    Enabled = true, 
    MaxDistance = 30, 
    TargetPart = "HumanoidRootPart"
}

local function getLocalRoot()
    if not playerCharacter then return nil end
    return playerCharacter:FindFirstChild("HumanoidRootPart") or playerCharacter:FindFirstChild("Torso")
end

local function GetNearParts(position, distance)
    local region = Region3.new(
        position - Vector3.new(distance, distance, distance), 
        position + Vector3.new(distance, distance, distance)
    )
    region = region:ExpandToGrid(4)
    return Workspace:FindPartsInRegion3(region, nil, math.huge)
end

local function getDirectionalVector(targetPos)
    local origin = getLocalRoot()
    if not origin then return Vector3.new(0, 0, 0) end
    return (targetPos - origin.Position).Unit * 1000
end

if hookmetamethod then
    local old
    old = hookmetamethod(game, "__namecall", function(self, ...)
        local args = {...}
        local method = getnamecallmethod()
        
        if not checkcaller() and self == Workspace and method == "Raycast" then
            if getgenv().SilentAimSettings.Enabled then
                local root = getLocalRoot()
                if root then
                    local nearestTarget = nil
                    local shortestDistance = getgenv().SilentAimSettings.MaxDistance
                    
                    for _, part in ipairs(GetNearParts(root.Position, getgenv().SilentAimSettings.MaxDistance)) do
                        if part.Name == "HumanoidRootPart" and not part.Anchored then
                            local char = part.Parent
                            if char and char ~= playerCharacter then
                                local humanoid = char:FindFirstChild("Humanoid")
                                if humanoid and humanoid.Health > 0 then
                                    local dist = (root.Position - part.Position).Magnitude
                                    if dist < shortestDistance then
                                        shortestDistance = dist
                                        nearestTarget = part
                                    end
                                end
                            end
                        end
                    end
                    
                    if nearestTarget then
                        args[2] = getDirectionalVector(nearestTarget.Position)
                    end
                end
            end
        end
        
        return old(self, unpack(args))
    end)
end
