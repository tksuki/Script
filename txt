local function startGrabLoop()
    grabLoop = task.spawn(function()
        local handCounter = 0

        while isGrabbing do
            if #selectedPlayers == 0 then task.wait(0.5) continue end

            local validTargets = {}
            for _, name in ipairs(selectedPlayers) do
                local p = Players:FindFirstChild(name)
                if p and checkPlayer(p) and not shouldSkip(p) then
                    table.insert(validTargets, p)
                end
            end

            if #validTargets == 0 then
                returnToSaved()
                task.wait(0.5)
                continue
            end

            for _, p in ipairs(validTargets) do
                if not isGrabbing then break end
                handCounter = handCounter + 1
                local hand = (handCounter % 2 == 1) and "Right" or "Left"
                executeGrabV2(p.Name, hand)
            end

            returnToSaved()
            task.wait(0.5)
        end
    end)
end

local function startGrabAllLoop()
    grabAllLoop = task.spawn(function()
        local handCounter = 0
        while isGrabbingAll do
            local validTargets = {}
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and checkPlayer(p) and not shouldSkip(p) then
                    table.insert(validTargets, p)
                end
            end
            if #validTargets == 0 then returnToSaved() task.wait(0.5) continue end
            for _, p in ipairs(validTargets) do
                if not isGrabbingAll then break end
                handCounter = handCounter + 1
                executeGrabV2(p.Name, (handCounter % 2 == 1) and "Right" or "Left")
            end
            returnToSaved()
            task.wait(0.5)
        end
    end)
end

local function startGrabAuraLoop()
    grabAuraLoop = task.spawn(function()
        local handCounter = 0
        local auraDebounce = {}
        while isGrabAura do
            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if myRoot then
                local myPos = myRoot.Position
                for _, player in ipairs(Players:GetPlayers()) do
                    if player ~= LocalPlayer and checkPlayer(player) and not shouldSkip(player) then
                        local tRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                        if tRoot and (tRoot.Position - myPos).Magnitude <= AURA_RADIUS then
                            local char = player.Character
                            if not auraDebounce[char] or (os.clock() - auraDebounce[char] > 3) then
                                auraDebounce[char] = os.clock()
                                handCounter = handCounter + 1
                                local hand = (handCounter % 2 == 1) and "Right" or "Left"
                                task.spawn(function()
                                    local tR = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                                    if not tR then return end

                                    local comp = getBlobmanComponents()
                                    local GrabEvents = ReplicatedStorage:FindFirstChild("GrabEvents")
                                    local SetNetworkOwner = GrabEvents and GrabEvents:FindFirstChild("SetNetworkOwner")
                                    local DestroyGrabLine = GrabEvents and GrabEvents:FindFirstChild("DestroyGrabLine")
                                    if not (comp and comp.GrabEvent and SetNetworkOwner) then return end

                                    local part = (hand == "Left") and comp.Left or comp.Right
                                    local rotationCFrame = CFrame.new(0,0,0,
                                        0.62931931, -0.479560107, 0.611538529,
                                        0, 0.786902189, 0.617077887,
                                        -0.777146816, -0.388339043, 0.495212734)

                                    -- ① 掴む
                                    comp.GrabEvent:FireServer(part.Detector, tR, part.Weld)

                                    -- ② 0.3秒待つ
                                    task.wait(0.3)

                                    -- ③ SetNetworkOwner
                                    tR = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                                    if not tR then return end
                                    SetNetworkOwner:FireServer(tR, CFrame.new(tR.Position) * rotationCFrame)

                                    -- ④ 0.05秒待つ
                                    task.wait(0.05)

                                    -- ⑤ 相手だけ真上35スタッド上昇
                                    tR = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                                    if not tR then return end
                                    local startPos = tR.Position
                                    local startTime = os.clock()
                                    while os.clock() - startTime < V2_RISE_TIME do
                                        tR = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                                        if not tR then break end
                                        local progress = (os.clock() - startTime) / V2_RISE_TIME
                                        tR.CFrame = CFrame.new(startPos.X, startPos.Y + V2_TARGET_HEIGHT * progress, startPos.Z)
                                        task.wait()
                                    end

                                    tR = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                                    if not tR then return end
                                    local finalCF = CFrame.new(startPos.X, startPos.Y + V2_TARGET_HEIGHT, startPos.Z)
                                    tR.CFrame = finalCF

                                    -- ⑥ DestroyGrabLine → 10回連続掴む
                                    task.wait(0.1)
                                    if DestroyGrabLine then DestroyGrabLine:FireServer(tR) end
                                    task.wait(0.1)

                                    for i = 1, V2_GRAB_COUNT do
                                        tR = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                                        if not tR then break end
                                        comp.GrabEvent:FireServer(part.Detector, tR, part.Weld)
                                        task.wait(0.05)
                                    end
                                end)
                            end
                        end
                    end
                end
            end
            task.wait(0.3)
        end
    end)
end

local function startAutoSitLoop()
    autoSitLoop = task.spawn(function()
        while isAutoSit do
            local myUsername = LocalPlayer.Name
            local mySpawnedToys = workspace:FindFirstChild(myUsername .. "SpawnedInToys")
            local Blobman = mySpawnedToys and mySpawnedToys:FindFirstChild("CreatureBlobman")

            if not Blobman then
                local myChar = LocalPlayer.Character
                local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
                if myRoot then
                    local spawnCF = myRoot.CFrame * CFrame.new(0, 0, -5)
                    local SpawnToyRF = ReplicatedStorage:FindFirstChild("MenuToys") and ReplicatedStorage.MenuToys:FindFirstChild("SpawnToyRemoteFunction")
                    if SpawnToyRF then pcall(function() SpawnToyRF:InvokeServer("CreatureBlobman", spawnCF, Vector3.new(0, 145.5, 0)) end) end
                end
                task.wait(0.5)
            else
                local seat = nil
                for _, v in ipairs(Blobman:GetDescendants()) do if v:IsA("Seat") or v:IsA("VehicleSeat") then seat = v break end end
                if seat then
                    local myHum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                    if myHum and myHum.SeatPart ~= seat then seat:Sit(myHum) end
                end
                task.wait(0.1)
            end
        end
    end)
end

