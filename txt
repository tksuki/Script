    Name = "Creature Tool (Full)",
    LoadingTitle = "Creature Tool",
    LoadingSubtitle = "by Script",
    Theme = "Default",
    ConfigurationSaving = { Enabled = false },
    KeySystem = false,
})

local MainTab = Window:CreateTab("メイン", 4483362458)

-- 状態管理変数
local isGrabbing = false
local isGrabbingAll = false
local skipInPlot = false
local excludeFriends = false
local isGrabAura = false
local isAutoSit = false

local grabAuraLoop = nil
local autoSitLoop = nil
local selectedPlayers = {}
local grabLoop = nil
local grabAllLoop = nil
local playerDropdownRef = nil
local savedPosition = nil


-- Vm.lua 2 に基づく判定設定
local AURA_RADIUS = 35
local IGNORE_HEIGHTS = {526.377685546875, 5.2832231521606445}
local VOID_Y_THRESHOLD = -25.072832107543945

--- ユーティリティ関数 ---

local function isPlayerInPlot(player)
    local char = player.Character
    if not char then return false end
    return char.Parent ~= workspace
end

local function checkPlayer(player)
    if player == LocalPlayer then return false end
    local char = player.Character
    if not char then return false end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return false end

    local playerY = root.Position.Y
    if playerY < VOID_Y_THRESHOLD then return false end
    for _, ignoreHeight in ipairs(IGNORE_HEIGHTS) do
        if math.abs(playerY - ignoreHeight) < 0.1 then return false end
    end
    return true
end

local function shouldSkip(player)
    if excludeFriends then
        local success, isFriend = pcall(function()
            return LocalPlayer:IsFriendsWith(player.UserId)
        end)
        if success and isFriend then return true end
    end
    if skipInPlot and isPlayerInPlot(player) then return true end
    return false
end

local function getPlayerNames()
    local names = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then table.insert(names, p.Name) end
    end
    return names
end

local function getTargetRoot(targetName)
    local t = Players:FindFirstChild(targetName)
    if not (t and t.Character) then return nil end
    return t.Character:FindFirstChild("HumanoidRootPart")
end

local function getBlobmanComponents()
    local myUsername = LocalPlayer.Name
    local mySpawnedToys = workspace:FindFirstChild(myUsername .. "SpawnedInToys")
    if not mySpawnedToys then return nil end
    local Blobman = mySpawnedToys:FindFirstChild("CreatureBlobman")
    if not Blobman then return nil end

    local BlobmanScript = Blobman:FindFirstChild("BlobmanSeatAndOwnerScript")
    local CreatureGrab = BlobmanScript and BlobmanScript:FindFirstChild("CreatureGrab")

    return {
        GrabEvent = CreatureGrab,
        Right = {
            Detector = Blobman:FindFirstChild("RightDetector"),
            Weld = Blobman:FindFirstChild("RightDetector") and Blobman.RightDetector:FindFirstChild("RightWeld")
        },
        Left = {
            Detector = Blobman:FindFirstChild("LeftDetector"),
            Weld = Blobman:FindFirstChild("LeftDetector") and Blobman.LeftDetector:FindFirstChild("LeftWeld")
        }
    }
end

local function returnToSaved()
    if savedPosition then
        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if myRoot then myRoot.CFrame = savedPosition end
    end
end

local function startGodMode()
    workspace.FallenPartsDestroyHeight = -9999999
end

local function stopGodMode()
    workspace.FallenPartsDestroyHeight = -500
end

--- v2コア処理 ---

local V2_TARGET_HEIGHT = 35
local V2_RISE_TIME     = 0.1
local V2_GRAB_COUNT    = 10

local function executeGrabV2(targetName, side)
    local tR = getTargetRoot(targetName)
    if not tR then return end

    local comp = getBlobmanComponents()
    local GrabEvents = ReplicatedStorage:FindFirstChild("GrabEvents")
    local SetNetworkOwner = GrabEvents and GrabEvents:FindFirstChild("SetNetworkOwner")
    local DestroyGrabLine = GrabEvents and GrabEvents:FindFirstChild("DestroyGrabLine")
    if not (comp and comp.GrabEvent and SetNetworkOwner) then return end

    local part = (side == "Left") and comp.Left or comp.Right
    local rotationCFrame = CFrame.new(0,0,0,
        0.62931931, -0.479560107, 0.611538529,
        0, 0.786902189, 0.617077887,
        -0.777146816, -0.388339043, 0.495212734)

    -- ① 自分をターゲットの横にTP
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if myRoot then
        myRoot.CFrame = CFrame.new(tR.Position.X + 5, tR.Position.Y, tR.Position.Z + 5)
    end
    task.wait(0.1)

    -- ② 掴む (1回)
    tR = getTargetRoot(targetName)
    if not tR then return end
    comp.GrabEvent:FireServer(part.Detector, tR, part.Weld)

    -- ③ 0.3秒待つ
    task.wait(0.3)

    -- ④ SetNetworkOwner を送る
    tR = getTargetRoot(targetName)
    if not tR then return end
    SetNetworkOwner:FireServer(tR, CFrame.new(tR.Position) * rotationCFrame)

    -- ⑤ 0.05秒待つ
    task.wait(0.05)

    -- ⑥ 0.1秒かけて真上35スタッド上昇
    tR = getTargetRoot(targetName)
    if not tR then return end
    local startPos = tR.Position
    local startTime = os.clock()
    while os.clock() - startTime < V2_RISE_TIME do
        tR = getTargetRoot(targetName)
        if not tR then break end
        local progress = (os.clock() - startTime) / V2_RISE_TIME
        local currentY = startPos.Y + (V2_TARGET_HEIGHT * progress)
        tR.CFrame = CFrame.new(startPos.X, currentY, startPos.Z)
        task.wait()
    end

    -- 最終位置確定
    tR = getTargetRoot(targetName)
    if not tR then return end
    local finalCF = CFrame.new(startPos.X, startPos.Y + V2_TARGET_HEIGHT, startPos.Z)
    tR.CFrame = finalCF

    -- ⑦ DestroyGrabLine → 10回連続掴む
    tR = getTargetRoot(targetName)
    if not tR then return end
    task.wait(0.1)
    if DestroyGrabLine then DestroyGrabLine:FireServer(tR) end
    task.wait(0.1)

    for i = 1, V2_GRAB_COUNT do
        tR = getTargetRoot(targetName)
        if not tR then break end
        comp.GrabEvent:FireServer(part.Detector, tR, part.Weld)
        task.wait(0.05)
    end
end

