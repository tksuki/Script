local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

local function findNearestPlayer()
	local character = LocalPlayer.Character
	if not character then return nil end
	
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not rootPart then return nil end
	
	local nearestPlayer = nil
	local nearestDistance = math.huge
	
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character then
			local targetRoot = player.Character:FindFirstChild("HumanoidRootPart")
			if targetRoot then
				local distance = (rootPart.Position - targetRoot.Position).Magnitude
				if distance < nearestDistance then
					nearestDistance = distance
					nearestPlayer = player
				end
			end
		end
	end
	
	return nearestPlayer
end

local function executeGrab()
	local myUsername = LocalPlayer.Name
	
	local nearestPlayer = findNearestPlayer()
	if not nearestPlayer then return end
	
	local targetUsername = nearestPlayer.Name
	
	local mySpawnedToys = workspace:FindFirstChild(myUsername .. "SpawnedInToys")
	if not mySpawnedToys then return end
	
	local creatureBlobman = mySpawnedToys:FindFirstChild("CreatureBlobman")
	if not creatureBlobman then return end
	
	local blobmanScript = creatureBlobman:FindFirstChild("BlobmanSeatAndOwnerScript")
	if not blobmanScript then return end
	
	local creatureGrab = blobmanScript:FindFirstChild("CreatureGrab")
	if not creatureGrab then return end
	
	local rightDetector = creatureBlobman:FindFirstChild("RightDetector")
	if not rightDetector then return end
	
	local rightWeld = rightDetector:FindFirstChild("RightWeld")
	if not rightWeld then return end
	
	local targetCharacter = workspace:FindFirstChild(targetUsername)
	if not targetCharacter then return end
	
	local targetRoot = targetCharacter:FindFirstChild("HumanoidRootPart")
	if not targetRoot then return end
	
	local myCharacter = LocalPlayer.Character
	local myRoot = myCharacter and myCharacter:FindFirstChild("HumanoidRootPart")
	if not myRoot then return end
	
	local grabEvents = ReplicatedStorage:FindFirstChild("GrabEvents")
	if not grabEvents then return end
	
	local setNetworkOwner = grabEvents:FindFirstChild("SetNetworkOwner")
	if not setNetworkOwner then return end
	
	local targetPos = targetRoot.Position
	
	local rotationCFrame = CFrame.new(
		0, 0, 0,
		0.62931931, -0.479560107, 0.611538529,
		0, 0.786902189, 0.617077887,
		-0.777146816, -0.388339043, 0.495212734
	)
	
	creatureGrab:FireServer(rightDetector, targetRoot, rightWeld)
	
	task.wait(0.05)
	
	local currentCFrame = CFrame.new(targetPos.X, targetPos.Y, targetPos.Z) * rotationCFrame
	setNetworkOwner:FireServer(targetRoot, currentCFrame)
	
	task.wait(0.05)
	
	local startTime = os.clock()
	local startPos = targetRoot.Position
	while os.clock() - startTime < 0.3 do
		local progress = (os.clock() - startTime) / 0.3
		local currentHeight = startPos.Y + (100 * progress)
		myRoot.CFrame = CFrame.new(startPos.X + 2, currentHeight, startPos.Z)
		targetRoot.CFrame = CFrame.new(startPos.X, currentHeight, startPos.Z)
		task.wait()
	end
	
	targetRoot.CFrame = CFrame.new(startPos.X, startPos.Y + 100, startPos.Z)
	myRoot.CFrame = CFrame.new(startPos.X + 2, startPos.Y + 100, startPos.Z)
	
	for i = 1, 3 do
		creatureGrab:FireServer(rightDetector, targetRoot, rightWeld)
		
		local fixedStartTime = os.clock()
		while os.clock() - fixedStartTime < 0.1 do
			targetRoot.CFrame = CFrame.new(startPos.X, startPos.Y + 100, startPos.Z)
			myRoot.CFrame = CFrame.new(startPos.X + 2, startPos.Y + 100, startPos.Z)
			task.wait()
		end
	end
end

executeGrab()
