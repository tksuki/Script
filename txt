local OrionLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/jadpy/suki/refs/heads/main/orion"))()
local Window = OrionLib:MakeWindow({Name = "サイレントエイム", HidePremium = false, SaveConfig = true, ConfigFolder = "PureSilent"})

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera

getgenv().Settings = {
    Enabled = false,
    MaxDistance = 30,
    TargetPart = "HumanoidRootPart"
}

local Tab = Window:MakeTab({Name = "めいん", Icon = "rbxassetid://4483345998"})
Tab:AddToggle({Name = "Silent Aim", Default = false, Callback = function(v) getgenv().Settings.Enabled = v end})
Tab:AddSlider({Name = "サイレントエイム範囲", Min = 10, Max = 200, Default = 30, Callback = function(v) getgenv().Settings.MaxDistance = v end})

local function getLocalChar()
    return LocalPlayer.Character
end

local function getLocalRoot()
    local char = getLocalChar()
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function GetNearParts(position, distance)
    local region = Region3.new(position - Vector3.new(distance, distance, distance), position + Vector3.new(distance, distance, distance))
    region = region:ExpandToGrid(4)
    return Workspace:FindPartsInRegion3(region, nil, math.huge)
end

local function getDirectionalVector(originalDir, targetPos, magnitude)
    local origin = getLocalRoot().Position
    return (targetPos - origin).Unit * magnitude
end

if hookmetamethod then
    local _namecallhook = nil
    _namecallhook = hookmetamethod(game, "__namecall", function(...)
        local data = {...}
        local wsref = data[1]
        local _namecallmethod = getnamecallmethod()
        
        if wsref and wsref == Workspace then
            if _namecallmethod == "Raycast" and getLocalChar() and getLocalRoot() then
                if getgenv().Settings.Enabled then
                    local omg
                    local omgDist = getgenv().Settings.MaxDistance
                    
                    for _, v in ipairs(GetNearParts(getLocalRoot().Position, getgenv().Settings.MaxDistance)) do
                        if not checkcaller() and not v.Anchored and v.Name == "HumanoidRootPart" then
                            local char = v.Parent
                            if char and char ~= getLocalChar() and not char:IsDescendantOf(getLocalChar()) then
                                local humanoid = char:FindFirstChild("Humanoid")
                                if humanoid and humanoid.Health > 0 then
                                    local dist = (getLocalRoot().Position - v.Position).Magnitude
                                    if dist <= omgDist then
                                        omgDist = dist
                                        omg = v
                                    end
                                end
                            end
                        end
                    end
                    
                    if omg then
                        data[3] = getDirectionalVector(data[2], omg.Position, 1000)
                        data[4] = RaycastParams.new()
                        data[4].FilterDescendantsInstances = {omg.Parent}
                        data[4].FilterType = Enum.RaycastFilterType.Include
                    end
                end
            end
        end
        return _namecallhook(unpack(data))
    end)
end

OrionLib:Init()
