local OrionLib = loadstring(game:HttpGet(('https://raw.githubusercontent.com/Polinorsik/Orion-Z-Library/refs/heads/main/README.md')))()
local Window = OrionLib:MakeWindow({Name="サイレントエイム", HidePremium=false, SaveConfig=true, ConfigFolder="SilentAimHub", IntroEnabled=true, IntroText="Silent Aim", IntroIcon="rbxassetid://4483345998"})

-- 必須サービスの取得
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera

-- サイレントエイムの設定テーブル
local SilentAimSettings = {
    Enabled = false, 
    MaxDistance = 30, 
    TargetPart = "HumanoidRootPart", 
    DisableThreshold = 0
}

-- ユーティリティ関数
local function getLocalRoot()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
end

local function isLookingDown()
    if SilentAimSettings.DisableThreshold == 0 then return false end
    local lookVector = Camera.CFrame.LookVector
    local threshold = 1 - (SilentAimSettings.DisableThreshold / 25) * 0.5
    return lookVector.Y < threshold
end

local function GetNearParts(position, distance)
    local region = Region3.new(
        position - Vector3.new(distance, distance, distance), 
        position + Vector3.new(distance, distance, distance)
    )
    region = region:ExpandToGrid(4)
    return Workspace:FindPartsInRegion3(region, nil, math.huge)
end

local function getDirectionalVector(originalDir, targetPos, magnitude)
    local root = getLocalRoot()
    if not root then return originalDir end
    local origin = root.Position
    return (targetPos - origin).Unit * magnitude
end

-- 簡易的なホワイトリスト判定（自分自身を対象外にする）
local function isWhitelisted(player)
    if not player then return false end
    if player == LocalPlayer then return true end
    return false
end

-- UI（ラインタブとサイレントエイム設定）
local LineTab = Window:MakeTab({Name="ラインタブ", Icon="rbxassetid://4483345998", PremiumOnly=false})

LineTab:AddSection({Name="サイレントエイム"})

LineTab:AddToggle({
    Name="Silent Aim", 
    Default=false, 
    Callback=function(v) 
        SilentAimSettings.Enabled = v 
    end
})

LineTab:AddSlider({
    Name="サイレントエイム範囲", 
    Min=10, 
    Max=200, 
    Default=30, 
    Callback=function(v) 
        SilentAimSettings.MaxDistance = v 
    end
})

LineTab:AddSlider({
    Name="サイレントエイム無効範囲", 
    Min=0, 
    Max=75, 
    Default=0, 
    Callback=function(v) 
        SilentAimSettings.DisableThreshold = v 
    end
})

-- フック（サイレントエイムのコアロジック）
if hookmetamethod then
    local _namecallhook = nil
    _namecallhook = hookmetamethod(game, "__namecall", function(...)
        local data = {...}
        local wsref = data[1]
        local _namecallmethod = getnamecallmethod()
        
        if wsref and wsref == Workspace then
            if _namecallmethod == "Raycast" and getLocalRoot() then
                if SilentAimSettings.Enabled and not isLookingDown() then
                    local omg
                    local omgDist = SilentAimSettings.MaxDistance
                    
                    for _, v in ipairs(GetNearParts(getLocalRoot().Position, SilentAimSettings.MaxDistance)) do
                        if not checkcaller() and not v.Anchored and v.Name == "HumanoidRootPart" then
                            local char = v.Parent
                            if char and char ~= LocalPlayer.Character and not char:IsDescendantOf(LocalPlayer.Character) then
                                local p = Players:GetPlayerFromCharacter(char)
                                if not isWhitelisted(p) then
                                    local humanoid = char:FindFirstChild("Humanoid")
                                    if humanoid and humanoid.Health > 0 then
                                        local dist = (getLocalRoot().Position - v.Position).Magnitude
                                        if dist <= omgDist then
                                            omgDist = dist
                                            omg = v
                                        end
                                    end
                                end
                            end
                        end
                    end
                    
                    if omg then
                        data[3] = getDirectionalVector(data[2], omg.Position, 1000)
                        data[4] = RaycastParams.new()
                        data[4].FilterDescendantsInstances = {omg.Parent}
                        data[4].FilterType = Enum.RaycastFilterType.Include
                    end
                end
            end
        end
        return _namecallhook(unpack(data))
    end)
end

OrionLib:Init()
