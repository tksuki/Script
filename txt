local OrionLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/jadpy/suki/refs/heads/main/orion"))()
local Window = OrionLib:MakeWindow({Name = "サイレントエイム", HidePremium = false, SaveConfig = true, ConfigFolder = "PureSilent"})
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera

getgenv().Settings = {
    Enabled = false,
    MaxDistance = 30,
    TargetPart = "HumanoidRootPart"
}

local Tab = Window:MakeTab({Name = "めいん", Icon = "rbxassetid://4483345998"})
Tab:AddToggle({Name = "Silent Aim", Default = false, Callback = function(v) getgenv().Settings.Enabled = v end})
Tab:AddSlider({Name = "サイレントエイム範囲", Min = 10, Max = 200, Default = 30, Callback = function(v) getgenv().Settings.MaxDistance = v end})

local function getLocalChar()
    return LocalPlayer.Character
end

local function getLocalRoot()
    local char = getLocalChar()
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getNearestTarget()
    local nearestTarget = nil
    local shortestDistance = getgenv().Settings.MaxDistance
    local localRoot = getLocalRoot()
    
    if not localRoot then return nil end
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local humanoid = player.Character:FindFirstChild("Humanoid")
            local targetPart = player.Character:FindFirstChild(getgenv().Settings.TargetPart)
            
            if humanoid and humanoid.Health > 0 and targetPart then
                local distance = (localRoot.Position - targetPart.Position).Magnitude
                
                if distance < shortestDistance then
                    shortestDistance = distance
                    nearestTarget = targetPart
                end
            end
        end
    end
    
    return nearestTarget
end

local old
old = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    
    if not checkcaller() and self == Workspace and method == "Raycast" then
        if getgenv().Settings.Enabled then
            local localRoot = getLocalRoot()
            if localRoot then
                local target = getNearestTarget()
                
                if target then
                    -- 元のOriginポイントを取得
                    local origin = args[1]
                    -- ターゲットへの新しい方向ベクトルを計算
                    local newDirection = (target.Position - origin).Unit * 1000
                    
                    -- 新しいRaycastParamsを作成
                    local newParams = RaycastParams.new()
                    newParams.FilterType = Enum.RaycastFilterType.Include
                    newParams.FilterDescendantsInstances = {target.Parent}
                    
                    -- 新しい引数でRaycastを実行
                    return old(self, origin, newDirection, newParams)
                end
            end
        end
    end
    
    return old(self, ...)
end))

OrionLib:Init()
