local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer
local playerCharacter = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
LocalPlayer.CharacterAdded:Connect(function(character) playerCharacter = character end)

local SilentAimSettings = {Enabled = false, MaxDistance = 30, TargetPart = "HumanoidRootPart"}

local whitelistedPlayers = {}

function isWhitelisted(player) 
    if not player then return false end 
    if player == LocalPlayer then return true end 
    return whitelistedPlayers[player.Name] 
end

local function getLocalRoot()
    if not playerCharacter then return nil end
    return playerCharacter:FindFirstChild("HumanoidRootPart") or playerCharacter:FindFirstChild("Torso")
end

local function GetNearParts(position, distance)
    local region = Region3.new(position - Vector3.new(distance, distance, distance), position + Vector3.new(distance, distance, distance))
    region = region:ExpandToGrid(4)
    return Workspace:FindPartsInRegion3(region, nil, math.huge)
end

local function getDirectionalVector(originalDir, targetPos, magnitude)
    local origin = getLocalRoot().Position
    return (targetPos - origin).Unit * magnitude
end

if hookmetamethod then
    local _namecallhook = nil
    _namecallhook = hookmetamethod(game, "__namecall", function(...)
        local data = {...}
        local wsref = data[1]
        local _namecallmethod = getnamecallmethod()
        
        if wsref and wsref == Workspace then
            if _namecallmethod == "Raycast" and getLocalRoot() then
                if SilentAimSettings.Enabled then
                    local omg
                    local omgDist = SilentAimSettings.MaxDistance
                    for _, v in ipairs(GetNearParts(getLocalRoot().Position, SilentAimSettings.MaxDistance)) do
                        if not checkcaller() and not v.Anchored and v.Name == "HumanoidRootPart" then
                            local char = v.Parent
                            if char and char ~= playerCharacter and not char:IsDescendantOf(playerCharacter) then
                                local p = Players:GetPlayerFromCharacter(char)
                                if not isWhitelisted(p) then
                                    local humanoid = char:FindFirstChild("Humanoid")
                                    if humanoid and humanoid.Health > 0 then
                                        local dist = (getLocalRoot().Position - v.Position).Magnitude
                                        if dist <= omgDist then
                                            omgDist = dist
                                            omg = v
                                        end
                                    end
                                end
                            end
                        end
                    end
                    if omg then
                        data[3] = getDirectionalVector(data[2], omg.Position, 1000)
                        data[4] = RaycastParams.new()
                        data[4].FilterDescendantsInstances = {omg.Parent}
                        data[4].FilterType = Enum.RaycastFilterType.Include
                    end
                end
            end
        end
        return _namecallhook(unpack(data))
    end)
end

SilentAimSettings.Enabled = true
