local function getCharacter()
    return LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
end

local function createPart()
    local Part = Instance.new("Part")
    Part.CanCollide = false
    Part.Anchored = true
    Part.Transparency = 1
    Part.Size = Vector3.new(4, 1, 4)
    Part.Parent = workspace
    return Part
end

local function createBodyMovers(Part)
    if Part:FindFirstChildOfClass("BodyPosition") then
        return Part:FindFirstChildOfClass("BodyGyro"), Part:FindFirstChildOfClass("BodyPosition")
    end
    local BP = Instance.new("BodyPosition")
    local BG = Instance.new("BodyGyro")
    BP.P, BP.D, BP.MaxForce = 15000, 200, Vector3.new(1,1,1) * 1e10
    BP.Parent = Part
    BG.P, BG.D, BG.MaxTorque = 15000, 200, Vector3.new(1,1,1) * 1e10
    BG.Parent = Part
    return BG, BP
end

-- ==========================================
-- バリア破壊用ユーティリティ
-- ==========================================
local function getLocalRoot()
    if not playerCharacter then return nil end
    return playerCharacter:FindFirstChild("HumanoidRootPart") or playerCharacter:FindFirstChild("Torso")
end

local function getInv()
    return Workspace:FindFirstChild(LocalPlayer.Name .. "SpawnedInToys")
end

local function spawntoy_v1(name, cframe, vector3)
    local toy = ReplicatedStorage.MenuToys.SpawnToyRemoteFunction:InvokeServer(name, cframe, vector3 or Vector3.zero)
    task.wait(0.1)
    local inv = getInv()
    if inv then
        return inv:FindFirstChild(name)
    end
    return toy
end

local function SetNetworkOwner_v1(part)
    local root = getLocalRoot()
    if root and part and SetNetworkOwner then
        SetNetworkOwner:FireServer(part, root.CFrame)
    end
end

local function destroyToy_v1(model)
    if model and DestroyToy then
        DestroyToy:FireServer(model)
    end
end

-- ==========================================
-- バリア破壊メイン
-- ==========================================
local function AttemptBarrierDestroy(showFailNotify)
    local root = getLocalRoot()
    if not root then return false end
    local original = root.CFrame

    -- 手順1: ハンバーガーを生成して持つ
    local burger = spawntoy_v1("FoodHamburger", root.CFrame)
    if burger and burger:FindFirstChild("HoldPart") then
        burger.HoldPart.HoldItemRemoteFunction:InvokeServer(burger, playerCharacter)
    end

    task.wait(0.05)
    -- 手順2: 判定用座標へ移動
    root.CFrame = CFrame.new(-521.46, 12.27, -175.27)
    task.wait(0.05)
    destroyToy_v1(burger)
    task.wait(0.05)
    root.CFrame = original

    -- 手順3: クライアント側で全バリアの衝突判定を無効化
    for _, plot in ipairs(Workspace.Plots:GetChildren()) do
        local barrier = plot:FindFirstChild("Barrier")
        if barrier then
            for _, p in ipairs(barrier:GetChildren()) do
                p.CanCollide = false
            end
        end
    end

    task.wait(1)

    -- 手順4: 消火器を座標に送り込んでサーバー側のバリアを破壊
    local ext = spawntoy_v1("FireExtinguisher", root.CFrame)
    if ext and ext:FindFirstChild("SoundPart") then
        SetNetworkOwner_v1(ext.SoundPart)
        task.wait(0.5)
        ext.SoundPart.CFrame = CFrame.new(-521.46, 12.27, -175.27)
        task.wait(0.75)

        if ext.Parent then
            OrionLib:MakeNotification({Name="Success", Content="バリア破壊成功！", Image="rbxassetid://4483345998", Time=3})
            destroyToy_v1(ext)
            return true
        end
    end

    if showFailNotify then
        OrionLib:MakeNotification({Name="Failure", Content="バリア破壊失敗", Image="rbxassetid://4483345998", Time=3})
    end

    pcall(function() destroyToy_v1(ext) end)
    return false
end

-- ==========================================
-- PlotItemsからオブジェクトを取得
-- ==========================================
local function getPlotItems()
    local results = {}
    local plotItems = workspace:FindFirstChild("PlotItems")
    if not plotItems then return results end

    for plotNum = 1, 5 do
        local plot = plotItems:FindFirstChild("Plot" .. plotNum)
        if plot then
            for _, item in ipairs(plot:GetChildren()) do
                if item:IsA("Model") then
                    local isOwned = false
                    for _, child in ipairs(item:GetDescendants()) do
                        if child:IsA("ObjectValue") then
                            local val = child.Value
                            if val and val:IsA("Player") and val == LocalPlayer then
                                isOwned = true
                                break
                            end
                        end
                    end
                    if isOwned then
                        if useMultipleObjects or item.Name == selectedObjectName then
                            table.insert(results, item)
                        end
                    end
                end
            end
        end
    end

    return results
end

local function getValidObjects()
    local toys = {}
    local folder = workspace:FindFirstChild(LocalPlayer.Name .. "SpawnedInToys")
    if folder then
        for _, toy in ipairs(folder:GetChildren()) do
            if toy:IsA("Model") and (useMultipleObjects or toy.Name == selectedObjectName) then
                table.insert(toys, toy)
            end
        end
    end
    if usePlotItems then
        for _, toy in ipairs(getPlotItems()) do
            table.insert(toys, toy)
        end
    end
    return toys
end

local function updateWingSpacing(newSpacing)
    wingSpacing = newSpacing
    if switch then
        offsets = {[1] = CFrame.new(-wingSpacing, 0, 1), [2] = CFrame.new(wingSpacing, 0, 1)}
    else
        offsets = {[1] = CFrame.new(-wingSpacing / 32.94, 0, 1), [2] = CFrame.new(wingSpacing / 32.94, 0, 1)}
    end
end

