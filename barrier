        Vector3.new(-0.3,1,0), Vector3.new(-0.5,0.75,0),
        Vector3.new(-0.5,0.25,0), Vector3.new(0.5,-0.75,0)
    },
    [" "] = {Vector3.new(0,0,0)}
}

-- ==========================================
-- システム実行
-- ==========================================
local function stopAll()
    if wingConnection then wingConnection:Disconnect(); wingConnection = nil end
    if textConnection then textConnection:Disconnect(); textConnection = nil end
    for _, w in ipairs(Wings) do
        if w.Handle then w.Handle:Destroy() end
        for _, seg in ipairs(w.Segments or {}) do
            if seg.Part then seg.Part:Destroy() end
        end
    end
    Wings = {}
    TextSync = {}
end

local function startWings()
    stopAll()
    local toys = getValidObjects()
    if #toys == 0 then return end

    for i = 1, 2 do
        local segments = {}
        for x = 1, wingL do table.insert(segments, {Part = createPart()}) end
        table.insert(Wings, {Handle = createPart(), Segments = segments, Side = i, Sync = {}, Reserved = nil})
    end

    for i, toy in ipairs(toys) do
        local side = i <= (#toys / 2) and 1 or 2
        local mainPart = toy:FindFirstChild("SoundPart")
        if not mainPart then
            for _, child in pairs(toy:GetChildren()) do
                if child:IsA("BasePart") then mainPart = child; break end
            end
        end
        for _, child in pairs(toy:GetChildren()) do
            if child:IsA("BasePart") then child.CanCollide = false end
        end
        if mainPart then
            local bg, bp = createBodyMovers(mainPart)
            local entry = {BG = bg, BP = bp}
            if not Wings[side].Reserved then
                Wings[side].Reserved = entry
            else
                table.insert(Wings[side].Sync, entry)
            end
        end
    end

    wingConnection = RunService.RenderStepped:Connect(function(dt)
        local char = getCharacter()
        if not char:FindFirstChild("HumanoidRootPart") then return end
        local torso = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
        if not torso then return end

        wingTime = wingTime + dt * (speed + Character.HumanoidRootPart.Velocity.Magnitude / 40)

        for i, w in ipairs(Wings) do
            task.spawn(function()
                local direction = (i == 1) and 1 or -1
                local flap = math.sin(wingTime) * math.rad(angle + (Character.HumanoidRootPart.Velocity.Magnitude / 4)) * direction
                w.Handle.CFrame = torso.CFrame * offsets[i] * CFrame.Angles(0, 0, flap)

                if w.Reserved then
                    w.Reserved.BP.Position = w.Handle.Position
                    local zAdj = (w.Side == 2) and 180 or 0
                    w.Reserved.BG.CFrame = w.Handle.CFrame * CFrame.Angles(math.rad(rotX), math.rad(rotY), math.rad(rotZ + zAdj))
                end

                for idx, seg in ipairs(w.Segments) do
                    local toFollow = (idx == 1) and w.Handle.CFrame or w.Segments[idx-1].Part.CFrame
                    seg.Part.CFrame = seg.Part.CFrame:Lerp(toFollow * offsets[i], 0.5)
                    if w.Sync[idx] then
                        w.Sync[idx].BP.Position = seg.Part.Position
                        local zAdj = (w.Side == 2) and 180 or 0
                        w.Sync[idx].BG.CFrame = seg.Part.CFrame * CFrame.Angles(math.rad(rotX), math.rad(rotY), math.rad(rotZ + zAdj))
                    end
                end
            end)
        end
    end)
end

local function startText()
    stopAll()
    local toys = getValidObjects()
    if #toys == 0 then return end

    local workText = drawText:upper()
    local len = #workText
    if len == 0 then return end

    for i, toy in ipairs(toys) do
        local mainPart = toy:FindFirstChild("SoundPart")
        if not mainPart then
            for _, child in pairs(toy:GetChildren()) do
                if child:IsA("BasePart") then mainPart = child; break end
            end
        end
        for _, child in pairs(toy:GetChildren()) do
            if child:IsA("BasePart") then child.CanCollide = false end
        end
        if mainPart then
            local bg, bp = createBodyMovers(mainPart)
            local charIdx = (math.floor((i-1) / objectsPerLetter) % len) + 1
            local subIdx = (i-1) % objectsPerLetter
            local pathOffset = subIdx / objectsPerLetter
            table.insert(TextSync, {
                BP = bp, BG = bg,
                Char = string.sub(workText, charIdx, charIdx),
                Idx = charIdx,
                PathOffset = pathOffset
            })
        end
    end

    textConnection = RunService.RenderStepped:Connect(function()
        local char = getCharacter()
        if not char:FindFirstChild("HumanoidRootPart") then return end
        local torso = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
        if not torso then return end

        local t = tick() * drawSpeed
        local baseCF = torso.CFrame * CFrame.new(0, 7, 4)
        local totalLen = #drawText
        local startX = ((totalLen - 1) * letterSpacing) / 2

        for _, sync in ipairs(TextSync) do
            local path = fontPaths[sync.Char] or fontPaths[" "]
            local pathLen = #path
            local prog = (t + sync.PathOffset * pathLen) % pathLen
            local i1 = math.floor(prog) + 1
            local i2 = (i1 % pathLen) + 1
            local pos = path[i1]:Lerp(path[i2], prog % 1)

            local targetPos = baseCF * CFrame.new(
                startX - (sync.Idx-1) * letterSpacing + (pos.X * letterSize),
                pos.Y * letterSize, 0
            )
            sync.BP.Position = targetPos.Position
            sync.BG.CFrame = targetPos * CFrame.Angles(math.rad(rotX), math.rad(rotY), math.rad(rotZ))
        end
    end)
end

